  (bottom (create true) (output "assembly/{{PROJECT}}_{{VERSION}}_PnP_{{VARIANT}}_BOT.csv"))
  (both (create false) (output "assembly/{{PROJECT}}_{{VERSION}}_PnP_{{VARIANT}}.csv"))
 )
